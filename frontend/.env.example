# ============================================================
# Task Tracker — Frontend Environment Configuration Reference
# ============================================================
# Copy this file to frontend/.env and set values for your environment.
# Vite only exposes variables prefixed with VITE_ to the browser.
# ============================================================

# Base URL for API requests made by the frontend.
# In development the Vite dev server proxies /api to localhost:8000,
# so this variable is optional and the default (/api/v1) is used automatically.
# Override when the API is hosted at a different URL than the frontend.
# VITE_API_URL=http://localhost:8000/api/v1
